const isLikelyTextOnly = (modelName) => {
  const name = modelName.toLowerCase();
  const textOnlyPatterns = ['3.5-turbo', 'gpt-3', 'deepseek-chat', 'deepseek-coder', 'claude-2', 'claude-instant', 'llama-3-8b'];
  const visionPatterns = ['vision', 'vl', '4o', 'pro', 'sonnet', 'opus', 'gemini'];
  if (visionPatterns.some(p => name.includes(p))) return false;
  if (textOnlyPatterns.some(p => name.includes(p))) return true;
  return false;
};

