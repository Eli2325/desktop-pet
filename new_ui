            <button className="px-2 py-1 bg-red-50 text-red-500 rounded text-[10px] font-bold">- 删除</button>
          </div>
        </div>
        <div className="flex items-center space-x-2">
          <span className="text-xs text-slate-600">选择对象：</span>
          <select className="flex-1 bg-slate-50 border rounded p-1.5 text-xs"><option>[应用·chat] Weixin</option></select>
        </div>
        <div className="border border-slate-200 rounded h-24 overflow-y-auto bg-slate-50 p-2 text-xs text-slate-600 space-y-1">
          <div className="p-1">又在和谁聊天呢？</div>
        </div>
        <label className="flex items-center space-x-2 text-xs text-blue-600 font-bold"><input type="checkbox" checked readOnly className="accent-blue-500"/><span>也使用类别通用文案（混合）</span></label>
      </section>

      <section className="bg-white border border-slate-200 rounded-xl p-5 shadow-sm space-y-3">
        <div className="flex justify-between items-center">
          <h3 className="text-sm font-bold text-slate-800">类别通用文案</h3>
          <div className="flex space-x-2">
            <button className="px-2 py-1 bg-slate-100 rounded text-[10px] font-bold">新增 Add</button>
            <button className="px-2 py-1 bg-red-50 text-red-500 rounded text-[10px] font-bold">删除 Delete</button>
            <button className="px-2 py-1 bg-slate-100 text-slate-600 rounded text-[10px] font-bold">恢复预设文案</button>
          </div>
        </div>
        <div className="flex items-center space-x-2">
          <span className="text-xs text-slate-600">类别：</span>
          <select className="flex-1 bg-slate-50 border rounded p-1.5 text-xs"><option>chat</option></select>
        </div>
        <div className="border border-slate-200 rounded h-24 overflow-y-auto bg-slate-50 p-2 text-xs text-slate-600 space-y-1">
          <div className="p-1">要找人说话吗。(来自预设)</div>
          <div className="p-1">聊完记得回来。(来自预设)</div>
        </div>
      </section>
    </div>
  );

  // ==================== 6. 过滤器 (Filters) ====================
  const renderFiltersTab = () => (
    <div className="space-y-6 max-w-2xl pb-4 animate-fade-in">
      <section className="bg-white border border-slate-200 rounded-xl p-5 shadow-sm space-y-3">
        <h3 className="text-sm font-bold text-slate-800">屏蔽进程列表</h3>
        <p className="text-[10px] text-slate-500">列表中的进程不会触发活动气泡，也不会被自动抓取</p>
        <div className="border border-slate-200 rounded h-32 overflow-y-auto bg-slate-50 p-2 text-xs text-slate-600 space-y-1">
          <div className="p-1">taskmgr.exe</div>
        </div>
        <div className="flex space-x-2">
          <button className="px-4 py-1.5 bg-blue-50 text-blue-600 rounded text-xs font-bold border border-blue-200">添加</button>
          <button className="px-4 py-1.5 bg-red-50 text-red-500 rounded text-xs font-bold border border-red-200">删除</button>
        </div>
      </section>

      <section className="bg-white border border-slate-200 rounded-xl p-5 shadow-sm space-y-3">
        <h3 className="text-sm font-bold text-slate-800">屏蔽标题关键词</h3>
        <p className="text-[10px] text-slate-500">窗口标题包含这些关键词时不会触发气泡</p>
        <div className="border border-slate-200 rounded h-32 overflow-y-auto bg-slate-50 p-2 text-xs text-slate-600 space-y-1">
          <div className="p-1">Desktop Pet Settings</div>
        </div>
        <div className="flex space-x-2">
          <button className="px-4 py-1.5 bg-blue-50 text-blue-600 rounded text-xs font-bold border border-blue-200">添加</button>
          <button className="px-4 py-1.5 bg-red-50 text-red-500 rounded text-xs font-bold border border-red-200">删除</button>
        </div>
      </section>
    </div>
  );

  // ==================== 7. AI 外置大脑 (AI) ====================
  const renderAITab = () => {
    const showTextOnlyWarning = isLikelyTextOnly(aiConfig.model);
    const isCustomUrl = aiConfig.apiUrl !== PROVIDER_CONFIGS[aiConfig.provider].defaultUrl;

    return (
      <div className="space-y-8 max-w-2xl pb-4 animate-fade-in">
        <section>
          <div className="flex items-center space-x-2 mb-4">
            <h3 className="text-sm font-bold text-slate-800 uppercase tracking-wider">接口与模型配置</h3>
            <div className="h-px flex-1 bg-slate-100"></div>
          </div>
          
          <div className="grid grid-cols-2 gap-4 bg-white p-5 rounded-xl border border-slate-200 shadow-sm">
            <div className="space-y-1.5">
              <label className="text-xs font-semibold text-slate-600">服务商 (Provider)</label>
              <select value={aiConfig.provider} onChange={(e) => handleProviderChange(e.target.value)} className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 text-sm text-slate-700 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all font-medium">
                {Object.entries(PROVIDER_CONFIGS).map(([key, config]) => (<option key={key} value={key}>{config.name}</option>))}
              </select>
            </div>
            <div className="space-y-1.5">
              <label className="text-xs font-semibold text-slate-600">API Key</label>
              <div className="relative">
                <input type={showApiKey ? "text" : "password"} value={aiConfig.apiKey} onChange={(e) => setAiConfig({...aiConfig, apiKey: e.target.value})} placeholder="sk-xxxxxxxx" className="w-full bg-slate-50 border border-slate-200 rounded-lg p-2.5 pr-10 text-sm text-slate-700 font-mono"/>
                <button onClick={() => setShowApiKey(!showApiKey)} className="absolute right-3 top-2.5 text-slate-400 hover:text-slate-600"><EyeOff size={16} /></button>
              </div>
            </div>
            
            <div className="col-span-2 space-y-1.5">
              <div className="flex justify-between items-end">
                <label className="text-xs font-semibold text-slate-600">接口代理地址 (Base URL)</label>
                {isCustomUrl && (
                  <span className="text-[10px] text-orange-500 font-medium flex items-center animate-fade-in">
                    <AlertTriangle size={10} className="mr-1" />已启用第三方通道
                  </span>
                )}
              </div>
              <div className="relative">
                <div className="absolute left-3 top-2.5 text-slate-400"><LinkIcon size={16} /></div>
                <input type="text" value={aiConfig.apiUrl} onChange={(e) => setAiConfig({...aiConfig, apiUrl: e.target.value})} className={`w-full bg-slate-50 border rounded-lg py-2.5 pl-9 pr-3 text-sm font-mono ${isCustomUrl ? 'border-orange-300 text-orange-700 focus:ring-orange-500/30' : 'border-slate-200 text-slate-700 focus:ring-blue-500/20'}`}/>
              </div>
            </div>

            <div className="col-span-2 space-y-1.5 mt-2 relative">
              <label className="text-xs font-semibold text-slate-600">视觉模型 (Model)</label>
              <div className="flex space-x-2">
                <input type="text" value={aiConfig.model} onChange={(e) => setAiConfig({...aiConfig, model: e.target.value})} className={`flex-1 bg-slate-50 border rounded-lg p-2.5 text-sm font-mono ${showTextOnlyWarning ? 'border-orange-400 focus:ring-orange-500/20' : 'border-slate-200 focus:ring-blue-500/20'}`}/>
                <button onClick={openModelFetcher} className="px-4 py-2.5 bg-gradient-to-r from-blue-500 to-indigo-500 hover:from-blue-600 text-white rounded-lg text-sm font-medium shadow-sm flex items-center space-x-1.5 shrink-0 active:scale-95"><Zap size={16} /><span>获取实时模型</span></button>
              </div>
              {showTextOnlyWarning && (
                <div className="mt-2 bg-orange-50 border border-orange-200 px-3 py-2 rounded-lg flex items-start space-x-2 animate-fade-in">
                  <AlertTriangle size={14} className="text-orange-500 mt-0.5 shrink-0" />
                  <p className="text-[10px] text-orange-700 font-medium">注意：当前模型似乎不支持视觉。开启屏幕截图抓取功能可能会导致报错。</p>
                </div>
              )}
            </div>
          </div>
        </section>

        <section className="bg-white p-5 rounded-xl border border-slate-200 shadow-sm space-y-5">
           <div className="bg-blue-50/50 border border-blue-100 rounded-xl p-4 space-y-3">
             <div className="flex justify-between items-center"><label className="text-sm font-semibold text-slate-700 flex items-center"><MessageSquare size={14} className="mr-1.5 text-blue-600" />气泡输出字数上限</label><span className="text-xs font-bold text-white bg-blue-500 px-2 py-1 rounded-md">{aiConfig.maxBubbleLength} 字</span></div>
             <input type="range" min="10" max="150" step="5" value={aiConfig.maxBubbleLength} onChange={(e) => setAiConfig({...aiConfig, maxBubbleLength: parseInt(e.target.value)})} className="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-500"/>
           </div>
           <div className="space-y-1.5">
             <label className="text-xs font-semibold text-slate-600">桌宠性格设定 (System Prompt)</label>
             <textarea value={aiConfig.systemPrompt} onChange={(e) => setAiConfig({...aiConfig, systemPrompt: e.target.value})} rows={3} className="w-full bg-slate-50 border border-slate-200 rounded-lg p-3 text-sm text-slate-700 resize-none"/>
           </div>
        </section>

        <section className="bg-white p-5 rounded-xl border border-slate-200 shadow-sm space-y-6">
            <div className="space-y-3">
              <div className="flex justify-between items-center"><label className="text-sm font-medium text-slate-700">定时自动看屏幕频率</label><span className="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded-md border border-blue-100">{aiConfig.autoScreenshotInterval === 0 ? '已关闭' : `每 ${aiConfig.autoScreenshotInterval} 分钟`}</span></div>
              <input type="range" min="0" max="120" step="1" value={aiConfig.autoScreenshotInterval} onChange={(e) => setAiConfig({...aiConfig, autoScreenshotInterval: parseInt(e.target.value)})} className="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-500"/>
            </div>
            <div className="space-y-3">
              <div className="flex justify-between items-center"><label className="text-sm font-medium text-slate-700">记住的历史对话轮数</label><span className="text-xs font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded-md border border-blue-100">上下文 {aiConfig.maxMemoryTurns} 轮</span></div>
              <input type="range" min="1" max="50" step="1" value={aiConfig.maxMemoryTurns} onChange={(e) => setAiConfig({...aiConfig, maxMemoryTurns: parseInt(e.target.value)})} className="w-full h-1.5 bg-slate-200 rounded-lg appearance-none cursor-pointer accent-blue-500"/>
            </div>
        </section>
      </div>
    );
  };

  const renderContent = () => {
    switch(activeTab) {
      case 'basic': return renderBasicTab();
      case 'behavior': return renderBehaviorTab();
      case 'rules': return renderRulesTab();
      case 'mapping': return renderMappingTab();
      case 'text': return renderTextTab();
      case 'filters': return renderFiltersTab();
      case 'ai': return renderAITab();
      default: return null;
    }
  };

  return (
    <div className="flex items-center justify-center min-h-screen bg-slate-200 p-8 font-sans relative">
      
      {/* 模态弹窗 (Model Fetcher) */}
      {showModelModal && (
        <div className="absolute inset-0 z-50 flex items-center justify-center bg-slate-900/40 backdrop-blur-sm animate-fade-in">
          <div className="w-[480px] bg-white rounded-2xl shadow-2xl overflow-hidden border border-slate-200">
            <div className="bg-slate-50 px-5 py-4 border-b border-slate-200 flex items-center justify-between">
              <div className="flex items-center space-x-2">
                <div className="w-8 h-8 rounded-full bg-blue-100 flex items-center justify-center text-blue-600"><Server size={16} /></div>
                <div><h3 className="font-bold text-slate-800 text-sm">在线获取可用模型</h3></div>
              </div>
              <button onClick={() => setShowModelModal(false)} className="p-1.5 text-slate-400 hover:text-slate-600 hover:bg-slate-200 rounded-lg"><X size={18} /></button>
            </div>
            <div className="p-5 min-h-[240px] max-h-[440px] overflow-y-auto scrollbar-thin">
              {modalStatus === 'loading' && (
                <div className="flex flex-col items-center justify-center h-48 space-y-4">
                  <Loader2 size={32} className="text-blue-500 animate-spin" />
                  <p className="text-sm text-slate-600 font-medium animate-pulse">正在穿梭网线探测支持视觉的模型...</p>
                </div>
              )}
              {modalStatus === 'error' && (
                <div className="flex flex-col items-center justify-center h-48 space-y-3 text-center">
                  <div className="w-12 h-12 bg-red-50 rounded-full flex items-center justify-center text-red-500 mb-2">
                    <AlertTriangle size={24} />
                  </div>
                  <p className="text-sm font-bold text-slate-800">在线拉取失败</p>
                  <p className="text-xs text-slate-500 px-8">可能是因为您尚未填写有效的 API Key，或者网络连接存在问题。</p>
                  <button onClick={() => setShowModelModal(false)} className="mt-4 px-6 py-2 bg-slate-100 hover:bg-slate-200 text-slate-700 rounded-lg text-sm font-medium">返回手动输入</button>
                </div>
              )}
              {modalStatus === 'success' && (
                <div className="space-y-3 animate-fade-in">
                  <div className="flex items-center space-x-2 text-sm text-green-600 bg-green-50 px-3 py-2 rounded-lg border border-green-100 mb-2">
                    <CheckCircle2 size={16} /> <span className="font-medium">探测成功！</span>
                  </div>
                  <div className="space-y-2">
                    {fetchedModels.map((model, idx) => {
                      const isTextOnly = isLikelyTextOnly(model.id);
                      return (
                      <div key={idx} className={`group flex items-center justify-between p-3 rounded-xl border transition-all ${isTextOnly ? 'border-orange-200 bg-orange-50/20' : 'border-slate-200 hover:border-blue-300 hover:bg-blue-50/30'}`}>
                        <div>
                          <div className="flex items-center space-x-2">
                            <p className={`text-sm font-bold font-mono ${isTextOnly ? 'text-orange-800' : 'text-slate-800'}`}>{model.id}</p>
                            {isTextOnly && <span className="text-[9px] font-bold bg-orange-100 text-orange-600 px-1.5 py-0.5 rounded border border-orange-200">纯文本</span>}
                          </div>
                          <p className="text-[10px] text-slate-500 mt-0.5">{model.desc}</p>
                        </div>
                        <button onClick={() => { setAiConfig(prev => ({ ...prev, model: model.id })); setShowModelModal(false); }} className={`opacity-0 group-hover:opacity-100 px-3 py-1.5 text-white rounded-lg text-xs font-medium transition-all ${isTextOnly ? 'bg-orange-500 hover:bg-orange-600' : 'bg-blue-500 hover:bg-blue-600'}`}>应用</button>
                      </div>
                    )})}
                  </div>
                </div>
              )}
            </div>
          </div>
        </div>
      )}

      {/* 主设置窗口 */}
      <div className="w-[960px] h-[700px] bg-white rounded-2xl shadow-2xl flex overflow-hidden border border-slate-200">
        
        {/* 左侧导航栏 */}
        <div className="w-[280px] bg-slate-50 border-r border-slate-200 flex flex-col shrink-0 z-10">
          <div className="p-6 border-b border-slate-200 flex items-center space-x-3 bg-white">
            <div className="w-10 h-10 rounded-xl bg-blue-500 flex items-center justify-center text-white shadow-md shadow-blue-500/30">
              <Sparkles size={20} />
            </div>
            <div>
              <h2 className="font-extrabold text-slate-800 text-lg tracking-tight">控制面板</h2>
              <p className="text-[10px] text-slate-500 font-medium tracking-wider uppercase mt-0.5">Desktop Pet v2.0</p>
            </div>
          </div>
          
          <div className="flex-1 overflow-y-auto py-4 px-3 space-y-1.5 scrollbar-none">
            {menuItems.map(item => {
              const Icon = item.icon;
              const isActive = activeTab === item.id;
              const isAi = item.id === 'ai';
              return (
                <button
                  key={item.id}
                  onClick={() => setActiveTab(item.id)}
                  className={`w-full flex items-center space-x-3 px-3 py-3.5 rounded-xl transition-all duration-300 ${
                    isActive && !isAi ? 'bg-white shadow-md border border-slate-200 text-blue-600 transform scale-[1.02]' 
                    : isActive && isAi ? 'bg-gradient-to-r from-blue-600 to-indigo-600 shadow-md border border-indigo-400 text-white transform scale-[1.02]'
                    : isAi ? 'bg-indigo-50/50 text-indigo-600 hover:bg-indigo-100/50 border border-indigo-100/50'
                    : 'text-slate-600 hover:bg-slate-200/50 hover:text-slate-900 border border-transparent'
                  }`}
                >
                  <Icon size={18} className={`${isActive && !isAi ? 'text-blue-500' : isActive && isAi ? 'text-white' : isAi ? 'text-indigo-500' : 'text-slate-400'} shrink-0`} />
                  <div className="text-left flex-1 min-w-0">
                    <div className={`text-sm font-bold truncate ${isActive && !isAi ? 'text-slate-800' : isActive && isAi ? 'text-white' : ''}`}>{item.label}</div>
                    <div className={`text-[10px] mt-0.5 truncate ${isActive && isAi ? 'text-indigo-100' : isAi ? 'text-indigo-400' : 'text-slate-400'}`}>{item.desc}</div>
                  </div>
                  {isActive && !isAi && <div className="w-1.5 h-1.5 rounded-full bg-blue-500 shrink-0 shadow-[0_0_8px_rgba(59,130,246,0.8)]" />}
                  {isActive && isAi && <div className="w-1.5 h-1.5 rounded-full bg-white shrink-0 shadow-[0_0_8px_rgba(255,255,255,0.8)]" />}
                </button>
              );
            })}
          </div>
        </div>

        {/* 右侧内容区 */}
        <div className="flex-1 flex flex-col bg-slate-50 relative overflow-hidden">
          <div className="h-20 px-8 flex items-center border-b border-slate-200 shrink-0 bg-white/80 backdrop-blur-md z-10 sticky top-0">
            <div className="flex flex-col">
              <h1 className="text-xl font-extrabold text-slate-800 flex items-center space-x-2">
                {React.createElement(menuItems.find(m => m.id === activeTab).icon, { className: activeTab === 'ai' ? "text-indigo-500" : "text-blue-500", size: 24 })}
                <span>{menuItems.find(m => m.id === activeTab).label}</span>
              </h1>
              <p className="text-xs text-slate-500 mt-1 font-medium">{menuItems.find(m => m.id === activeTab).desc}</p>
            </div>
          </div>

          <div className="flex-1 overflow-y-auto p-8 scrollbar-thin bg-slate-50/50">
            {renderContent()}
          </div>

          <div className="h-16 border-t border-slate-200 bg-white flex items-center justify-end px-6 space-x-3 shrink-0 z-10">
            <button className="px-6 py-2.5 rounded-xl text-sm font-bold text-slate-500 hover:bg-slate-100 transition-colors">
              关闭
            </button>
            <button className="px-6 py-2.5 rounded-xl text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-md shadow-blue-500/20 flex items-center space-x-1.5 active:scale-95">
              <Save size={16} />
              <span>保存并应用</span>
            </button>
          </div>

        </div>
      </div>
    </div>
  );
};

export default SettingsUI;